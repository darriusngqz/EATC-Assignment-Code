# Copy this file to .streamlit/secrets.toml and fill in a real key.
# .streamlit/secrets.toml is gitignored on purpose, never commit a real key.
#
# VIRUSTOTAL_API_KEY enables the optional VirusTotal informational check on
# the Upload tab (see app.py's check_virustotal). It is entirely optional:
# if this key is missing, that check is silently skipped and the rest of
# the app (including the NSRL check) works exactly the same.
#
# Get a free key at https://www.virustotal.com/gui/join-us (sign up
# yourself, this is not something anyone else should do on your behalf).
# Free tier: 500 requests/day, 4 requests/minute.
#
# On Streamlit Community Cloud, set this in the app's Settings -> Secrets
# box instead of uploading a secrets.toml file.

VIRUSTOTAL_API_KEY = "your-key-here"
